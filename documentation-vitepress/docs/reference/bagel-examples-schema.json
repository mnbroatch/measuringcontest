{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boardgameengine.com/schemas/bagel-examples-subset.json",
  "title": "B.A.G.E.L. Game (Examples Subset)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" },
      "minItems": 1
    },
    "sharedBoard": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityMatcher" }
    },
    "personalBoard": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityMatcher" }
    },
    "initialPlacements": {
      "type": "array",
      "items": { "$ref": "#/$defs/initialPlacement" }
    },
    "numPlayers": {
      "type": "integer",
      "minimum": 1
    },
    "minPlayers": {
      "type": "integer",
      "minimum": 1
    },
    "maxPlayers": {
      "type": "integer",
      "minimum": 1
    },
    "turn": {
      "$ref": "#/$defs/turnConfig"
    },
    "moves": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/moveDefinition" }
    },
    "initialMoves": {
      "type": "array",
      "items": { "$ref": "#/$defs/moveRule" }
    },
    "phases": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/phaseConfig" }
    },
    "endIf": {
      "type": "array",
      "items": { "$ref": "#/$defs/endRule" }
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["numPlayers"] },
        { "required": ["minPlayers", "maxPlayers"] }
      ]
    }
  ],
  "$defs": {
    "entity": {
      "oneOf": [
        { "$ref": "#/$defs/entityGrid" },
        { "$ref": "#/$defs/entitySpace" },
        { "$ref": "#/$defs/entityGeneric" }
      ]
    },
    "entityCommon": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "perPlayer": { "type": "boolean" },
        "count": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "enum": ["Infinity"] }
          ]
        },
        "state": {
          "type": "object",
          "additionalProperties": true
        },
        "displayProperties": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contentsHiddenFrom": {
          "type": "string",
          "enum": ["All", "Others"]
        }
      },
      "required": ["name"]
    },
    "entityGrid": {
      "allOf": [
        { "$ref": "#/$defs/entityCommon" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "entityType": { "const": "Grid" },
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          },
          "required": ["entityType", "width", "height"]
        }
      ]
    },
    "entitySpace": {
      "allOf": [
        { "$ref": "#/$defs/entityCommon" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "entityType": { "const": "Space" }
          },
          "required": ["entityType"]
        }
      ]
    },
    "entityGeneric": {
      "allOf": [
        { "$ref": "#/$defs/entityCommon" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "entityType": false
          }
        }
      ]
    },
    "entityMatcher": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" }
      },
      "minProperties": 1
    },
    "initialPlacement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity": {
          "type": "object",
          "additionalProperties": true
        },
        "destination": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "index": { "type": "integer", "minimum": 0 },
            "name": { "type": "string" }
          }
        }
      },
      "required": ["entity", "destination"]
    },
    "turnConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minMoves": {
          "type": "integer",
          "minimum": 0
        },
        "maxMoves": {
          "type": "integer",
          "minimum": 1
        },
        "initialMoves": {
          "type": "array",
          "items": { "$ref": "#/$defs/moveRule" }
        },
        "activePlayers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "stages": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stageConfig" }
        },
        "order": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "playOrder": {
              "type": "string",
              "enum": ["RotateFirst"]
            }
          }
        }
      }
    },
    "stageConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initialMoves": {
          "type": "array",
          "items": { "$ref": "#/$defs/moveRule" }
        },
        "moves": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/moveDefinition" }
        }
      }
    },
    "phaseConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": { "type": "boolean" },
        "next": { "type": "string" },
        "turn": { "$ref": "#/$defs/turnConfig" },
        "moves": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/moveDefinition" }
        },
        "initialMoves": {
          "type": "array",
          "items": { "$ref": "#/$defs/moveRule" }
        },
        "endIf": {
          "type": "array",
          "items": { "$ref": "#/$defs/endRule" }
        }
      }
    },
    "moveDefinition": {
      "oneOf": [
        { "$ref": "#/$defs/movePlaceNew" },
        { "$ref": "#/$defs/moveMoveEntity" },
        { "$ref": "#/$defs/moveRemoveEntity" },
        { "$ref": "#/$defs/moveTakeFrom" },
        { "$ref": "#/$defs/moveSetState" },
        { "$ref": "#/$defs/moveSetActivePlayers" },
        { "$ref": "#/$defs/moveEndTurn" },
        { "$ref": "#/$defs/movePassTurn" },
        { "$ref": "#/$defs/moveForEach" },
        { "$ref": "#/$defs/moveShuffle" }
      ]
    },
    "moveRule": { "$ref": "#/$defs/moveDefinition" },
    "moveCommon": {
      "type": "object",
      "properties": {
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/$defs/moveDefinition" }
        }
      }
    },
    "movePlaceNew": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "PlaceNew" },
            "matchMultiple": { "type": "boolean" },
            "entity": { "type": "object", "additionalProperties": true },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "destination": { "type": "object", "additionalProperties": true }
              },
              "required": ["destination"]
            }
          },
          "required": ["moveType", "entity", "arguments"]
        }
      ]
    },
    "moveMoveEntity": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "MoveEntity" },
            "position": { "type": "string", "enum": ["First"] },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "entity": { "type": "object", "additionalProperties": true },
                "destination": { "type": "object", "additionalProperties": true }
              },
              "required": ["entity", "destination"]
            }
          },
          "required": ["moveType", "arguments"]
        }
      ]
    },
    "moveRemoveEntity": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "RemoveEntity" },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "entity": {}
              },
              "required": ["entity"]
            }
          },
          "required": ["moveType", "arguments"]
        }
      ]
    },
    "moveTakeFrom": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "TakeFrom" },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "source": { "type": "object", "additionalProperties": true },
                "destination": { "type": "object", "additionalProperties": true }
              },
              "required": ["source", "destination"]
            }
          },
          "required": ["moveType", "arguments"]
        }
      ]
    },
    "moveSetState": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "SetState" },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "entity": {},
                "state": { "$ref": "#/$defs/stateUpdate" }
              },
              "required": ["entity", "state"]
            }
          },
          "required": ["moveType", "arguments"]
        }
      ]
    },
    "stateUpdate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "property": { "type": "string" },
        "value": {},
        "possibleValues": {
          "type": "array",
          "items": {}
        },
        "playerChoice": { "type": "boolean" }
      },
      "required": ["property"],
      "anyOf": [
        { "required": ["value"] },
        { "required": ["possibleValues"] }
      ]
    },
    "moveSetActivePlayers": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "SetActivePlayers" },
            "options": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": ["moveType", "options"]
        }
      ]
    },
    "moveEndTurn": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "EndTurn" }
          },
          "required": ["moveType"]
        }
      ]
    },
    "movePassTurn": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "PassTurn" }
          },
          "required": ["moveType"]
        }
      ]
    },
    "moveForEach": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "ForEach" },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "targets": {}
              },
              "required": ["targets"]
            },
            "move": { "$ref": "#/$defs/moveDefinition" }
          },
          "required": ["moveType", "arguments", "move"]
        }
      ]
    },
    "moveShuffle": {
      "allOf": [
        { "$ref": "#/$defs/moveCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moveType": { "const": "Shuffle" },
            "arguments": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "target": { "type": "object", "additionalProperties": true }
              },
              "required": ["target"]
            }
          },
          "required": ["moveType", "arguments"]
        }
      ]
    },
    "endRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "result": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "winner": {
              "oneOf": [
                { "type": "string" },
                { "$ref": "#/$defs/valueRef" }
              ]
            },
            "winners": { "$ref": "#/$defs/valueRef" },
            "draw": { "type": "boolean" }
          }
        }
      },
      "required": ["conditions"]
    },
    "condition": {
      "oneOf": [
        { "$ref": "#/$defs/conditionShorthandString" },
        { "$ref": "#/$defs/conditionShorthandEntityType" },
        { "$ref": "#/$defs/conditionTyped" }
      ]
    },
    "conditionShorthandString": {
      "type": "string",
      "enum": ["isEmpty", "isCurrentPlayer"]
    },
    "conditionShorthandEntityType": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entityType": { "type": "string", "enum": ["Space"] }
      },
      "required": ["entityType"]
    },
    "conditionTyped": {
      "oneOf": [
        { "$ref": "#/$defs/conditionHasLine" },
        { "$ref": "#/$defs/conditionIsFull" },
        { "$ref": "#/$defs/conditionNoPossibleMoves" },
        { "$ref": "#/$defs/conditionPosition" },
        { "$ref": "#/$defs/conditionContainsSame" },
        { "$ref": "#/$defs/conditionIs" },
        { "$ref": "#/$defs/conditionContains" },
        { "$ref": "#/$defs/conditionNot" },
        { "$ref": "#/$defs/conditionOr" },
        { "$ref": "#/$defs/conditionSome" },
        { "$ref": "#/$defs/conditionEvery" },
        { "$ref": "#/$defs/conditionInLine" },
        { "$ref": "#/$defs/conditionEvaluate" }
      ]
    },
    "targetSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "matchMultiple": { "type": "boolean" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditions"]
    },
    "conditionHasLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "HasLine" },
        "target": { "type": "string" },
        "sequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineSequenceStep" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "target", "sequence"]
    },
    "lineSequenceStep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minCount": { "type": "integer", "minimum": 0 },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditions"]
    },
    "conditionIsFull": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "IsFull" },
        "target": { "type": "string" }
      },
      "required": ["conditionType", "target"]
    },
    "conditionNoPossibleMoves": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "NoPossibleMoves" }
      },
      "required": ["conditionType"]
    },
    "conditionPosition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Position" },
        "position": { "type": "string", "enum": ["First"] }
      },
      "required": ["conditionType", "position"]
    },
    "conditionContainsSame": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "ContainsSame" },
        "properties": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "properties"]
    },
    "conditionIs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Is" },
        "target": {
          "oneOf": [
            { "$ref": "#/$defs/valueRef" },
            { "$ref": "#/$defs/targetSelector" },
            { "type": "string" }
          ]
        },
        "matcher": {
          "type": "object",
          "additionalProperties": true
        },
        "entity": { "$ref": "#/$defs/valueRef" }
      },
      "required": ["conditionType"],
      "anyOf": [
        { "required": ["matcher"] },
        { "required": ["entity"] }
      ]
    },
    "conditionContains": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Contains" },
        "target": {
          "oneOf": [
            { "$ref": "#/$defs/valueRef" },
            { "$ref": "#/$defs/targetSelector" },
            { "type": "string" }
          ]
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditionType"]
    },
    "conditionNot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Not" },
        "target": {
          "oneOf": [
            { "$ref": "#/$defs/valueRef" },
            { "$ref": "#/$defs/targetSelector" },
            { "type": "string" }
          ]
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "conditions"]
    },
    "conditionOr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Or" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "conditions"]
    },
    "conditionSome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Some" },
        "target": { "$ref": "#/$defs/targetSelector" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "target", "conditions"]
    },
    "conditionEvery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Every" },
        "target": { "$ref": "#/$defs/targetSelector" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "target", "conditions"]
    },
    "conditionInLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "InLine" },
        "target": { "$ref": "#/$defs/valueRef" },
        "sequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineSequenceStep" },
          "minItems": 1
        }
      },
      "required": ["conditionType", "sequence"]
    },
    "conditionEvaluate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionType": { "const": "Evaluate" },
        "expression": { "type": "string" },
        "arguments": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/valueRef" }
        }
      },
      "required": ["conditionType", "expression", "arguments"]
    },
    "valueRef": {
      "oneOf": [
        { "$ref": "#/$defs/ctxPathRef" },
        { "$ref": "#/$defs/contextPathRef" },
        { "$ref": "#/$defs/gamePathRef" },
        { "$ref": "#/$defs/expressionRef" },
        { "$ref": "#/$defs/relativeCoordinatesRef" },
        { "$ref": "#/$defs/coordinatesRef" },
        { "$ref": "#/$defs/relativePathRef" },
        { "$ref": "#/$defs/parentRef" },
        { "$ref": "#/$defs/mapRef" },
        { "$ref": "#/$defs/mapMaxRef" },
        { "$ref": "#/$defs/pickRef" },
        { "$ref": "#/$defs/countRef" }
      ]
    },
    "ctxPathRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "ctxPath" },
        "path": {
          "type": "array",
          "items": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
          "minItems": 1
        }
      },
      "required": ["type", "path"]
    },
    "contextPathRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "contextPath" },
        "path": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "integer" },
              {
                "type": "object",
                "properties": {
                  "flatten": { "type": "boolean" },
                  "map": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            ]
          },
          "minItems": 1
        }
      },
      "required": ["type", "path"]
    },
    "gamePathRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "gamePath" },
        "path": {
          "type": "array",
          "items": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
          "minItems": 1
        }
      },
      "required": ["type", "path"]
    },
    "expressionRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "expression" },
        "expression": { "type": "string" },
        "arguments": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/valueRef" }
        }
      },
      "required": ["type", "expression", "arguments"]
    },
    "relativeCoordinatesRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "relativeCoordinates" },
        "target": { "$ref": "#/$defs/valueRef" },
        "location": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 2,
              "maxItems": 2
            },
            { "$ref": "#/$defs/valueRef" }
          ]
        }
      },
      "required": ["type", "location"]
    },
    "coordinatesRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "coordinates" },
        "target": { "$ref": "#/$defs/valueRef" }
      },
      "required": ["type"]
    },
    "relativePathRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "relativePath" },
        "target": { "$ref": "#/$defs/valueRef" },
        "path": {
          "type": "array",
          "items": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
          "minItems": 1
        }
      },
      "required": ["type", "target", "path"]
    },
    "parentRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "parent" },
        "target": { "$ref": "#/$defs/valueRef" }
      },
      "required": ["type"]
    },
    "mapRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
